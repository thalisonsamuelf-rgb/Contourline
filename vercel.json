{
  "rewrites": [
    { "source": "/portal", "destination": "/portal/index.html" },
    { "source": "/dashboard", "destination": "/dashboard/index.html" },
    { "source": "/fechamento", "destination": "/fechamento/index.html" },
    { "source": "/mapa", "destination": "/mapa/index.html" },
    { "source": "/rdstation", "destination": "/rdstation/index.html" },
    { "source": "/academy", "destination": "/academy/index.html" },
    { "source": "/login", "destination": "/login/index.html" },
    { "source": "/admin", "destination": "/admin/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
