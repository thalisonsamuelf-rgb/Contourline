NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Recommended for server-side workspace reads.
# WDP views currently require authenticated/member access, so the dashboard
# should use a service role key in RSC until auth is wired in a later story.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# The site-aiox workspace dashboard reads the WDP pilot workspace by default.
SITE_AIOX_WORKSPACE_SLUG=aiox
