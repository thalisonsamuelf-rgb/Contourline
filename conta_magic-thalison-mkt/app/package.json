{
  "name": "aiox-design-starter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run tokens:sync:write && next dev --webpack",
    "dev:variant2": "STARTER_VARIANT=variant2 npm run dev",
    "build": "npm run tokens:sync:write && next build --webpack",
    "build:variant2": "STARTER_VARIANT=variant2 npm run build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test:tenant-runtime": "node scripts/run-tenant-runtime-test.cjs",
    "scaffold:variant": "node scripts/scaffold-starter-variant.cjs",
    "storybook": "npm run tokens:sync:write && storybook dev -p 6007",
    "build-storybook": "npm run tokens:sync:write && storybook build",
    "generate-videos": "npx tsx scripts/generate-showcase-videos.ts",
    "generate-videos:dry": "npx tsx scripts/generate-showcase-videos.ts --dry-run",
    "generate-videos:tenis": "npx tsx scripts/generate-showcase-videos.ts --category=tenis",
    "generate-videos:jaquetas": "npx tsx scripts/generate-showcase-videos.ts --category=jaquetas",
    "tokens:sync": "node scripts/sync-dtcg-tokens.cjs",
    "tokens:sync:write": "node scripts/sync-dtcg-tokens.cjs --write",
    "tokens:sync:json": "node scripts/sync-dtcg-tokens.cjs --json",
    "export:standalone": "node scripts/export-standalone-app.cjs"
  },
