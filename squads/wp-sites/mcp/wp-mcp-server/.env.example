# WordPress MCP Server - Configuração
# Copie para .env e preencha com seus dados

# URL do site WordPress (sem barra final)
WP_URL=https://seusite.com.br

# Usuário WordPress com permissão de administrador
WP_USER=admin

# Application Password (gerado em: WP Admin > Usuários > Seu Perfil > Application Passwords)
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
